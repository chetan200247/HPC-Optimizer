    <!-- Carbon intensity calculation -->
    <mxCell id="calcCI" value="&lt;b&gt;CARBON INTENSITY CALCULATION&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;For each hour, carbon intensity (CI) is computed as the generation-weighted&lt;br/&gt;average of IPCC AR5 lifecycle emission factors:&lt;br/&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;CI (gCO₂/kWh)  =  Σ [ Generation_fuel (MWh) × EF_fuel (gCO₂/kWh) ]&lt;br/&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;────────────────────────────────────&lt;br/&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Total Generation (MWh)&lt;br/&gt;&lt;br/&gt;Emission factors (IPCC AR5): Coal 1,000 · Gas 450 · Oil 800 · Nuclear 0 · Solar 0 · Hydro 0 · Wind 0&lt;br/&gt;Result: historical CI dataset for TVA grid, 2019–2022 (35,064 hourly records)&lt;br/&gt;Actual TVA mean CI: 283 gCO₂/kWh  |  Range: 76 – 500 gCO₂/kWh"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=14;spacingRight=12;spacingTop=8;fontSize=12;verticalAlign=top;"
      vertex="1" parent="1">
      <mxGeometry x="500" y="1120" width="800" height="245" as="geometry"/>
    </mxCell>

